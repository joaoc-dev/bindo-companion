######################################################################
# .NET / Visual Studio / MSBuild
######################################################################

## Build outputs
**/bin/
**/obj/

## Visual Studio / VS Code
.vs/
**/*.user
**/*.suo
**/*.userosscache
**/*.sln.docstates
.vscode/

## Test results
**/TestResults/

## Misc build artifacts
**/*.pdb
**/*.cache
**/*.log

######################################################################
# Node / Vite (frontend)
######################################################################

## Dependencies & build output
**/node_modules/
**/dist/
**/.vite/

## Vite env files: ignore ONLY local variants
**/.env.local
**/.env.*.local

######################################################################
# Orval / repo-root Node (OpenAPI client generation)
######################################################################

# OpenAPI polling / watch scripts may write this (see patchnuts-style workflows).
.openapi-cache.json
**/.openapi-cache.json

# Generated API client (orval); regenerate with `npm run generate:api` (APIs must be up).
packages/api-client/api/generated/

# OpenAPI spec snapshots from `npm run export:openapi` (optional local cache).
openapi-companion.json
openapi-skull-king.json

**/.eslintcache

######################################################################
# OS noise
######################################################################

Thumbs.db
Desktop.ini
.DS_Store
